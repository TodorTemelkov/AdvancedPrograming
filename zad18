// Vasiot kod ovde
class Category{
    private String name;

    @Override
    public boolean equals(Object o) {
        if (this == o) return true;
        if (o == null || getClass() != o.getClass()) return false;
        Category category = (Category) o;
        return Objects.equals(name, category.name);
    }

    @Override
    public int hashCode() {
        return Objects.hashCode(name);
    }

    public Category(String name) {
        this.name = name;

    }

    public String getName() {
        return name;
    }
}
abstract class NewsItem{
    private String title;
    private Date date;
    private Category category;

    public NewsItem(String title, Date date, Category category) {
        this.title = title;
        this.date = date;
        this.category = category;
    }

    public String getTitle() {
        return title;
    }

    public Date getDate() {
        return date;
    }

    public Category getCategory() {
        return category;
    }

    public void setTitle(String title) {
        this.title = title;
    }

    public void setDate(Date date) {
        this.date = date;
    }

    public void setCategory(Category category) {
        this.category = category;
    }
    public abstract String getTeaser();

}
class MediaNewsItem extends NewsItem{
    private String mediaUrl;
    private int views;
    public MediaNewsItem(String title, Date date, Category category, String mediaUrl, int views) {
        super(title, date, category);
        this.mediaUrl = mediaUrl;
        this.views = views;
    }
    public String getTeaser(){
        long diffMillis = new Date().getTime() - getDate().getTime();
        long minutesAgo = diffMillis / (60 * 1000);
        return String.format("%s\n%d\n%s\n%d\n", getTitle(), minutesAgo, mediaUrl, views);
    }
}

class TextNewsItem extends NewsItem{
    private String text;
    public TextNewsItem(String title, Date date, Category category, String text) {
        super(title, date, category);
        this.text = text;
    }
    public String getTeaser(){
        long diffMillis = new Date().getTime() - getDate().getTime();
        long minutesAgo = diffMillis / (60 * 1000);
        String shortened = text.length() > 80 ? text.substring(0, 80) : text;
        return String.format("%s\n%d\n%s\n", getTitle(), minutesAgo, shortened);
    }
}
class FrontPage {
    private final Category[] categories;
    private final List<NewsItem> newsItems;

    public FrontPage(Category[] categories) {
        this.categories = categories;
        this.newsItems = new ArrayList<>();
    }

    public void addNewsItem(NewsItem newsItem) {
        newsItems.add(newsItem);
    }

    public List<NewsItem> listByCategory(Category category) {
        return newsItems.stream().filter(newsItem -> newsItem.getCategory().equals(category)).collect(Collectors.toList());
    }

    @Override
    public String toString() {
        return newsItems.stream().map(NewsItem::getTeaser).collect(Collectors.joining());
    }

    public List<NewsItem> listByCategoryName(String category) throws CategoryNotFoundException {
        for (int i = 0; i < categories.length; i++) {
            if (categories[i].getName().equals(category)) {
                return newsItems.stream().filter(newsItem -> newsItem.getCategory().getName().equals(category)).collect(Collectors.toList());
            }
        }
        throw new CategoryNotFoundException("Category "+category+" was not found");

    }
}
class CategoryNotFoundException extends Exception {
    public CategoryNotFoundException(String message) {
        super(message);
    }
}
