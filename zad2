abstract class Shape implements Comparable<Shape> {
    String type;
    private double size;

    public Shape(String type, double size) {
        this.type = type;
        this.size = size;
    }

    public String getType() {
        return type;
    }

    public double getSize() {
        return size;
    }
    @Override
    public int compareTo(Shape o) {
        return Comparator.comparing(Shape::getArea).compare(this, o);
    }


    abstract double getArea();
}
class Square extends Shape {

    public Square(String type, double size) {
        super(type, size);
    }

    @Override
    double getArea() {
        return getSize()*getSize();
    }
}
class Circle extends Shape {
    public Circle(String type, double size) {
        super(type, size);
    }

    @Override
    double getArea() {
        return Math.PI * getSize() * getSize();
    }

}
class Canvas implements Comparable<Canvas> {
    private List<Shape> shapes;
    private String CanvasID;


    public Canvas(List<Shape> shapes, String canvasID) {
        this.shapes = shapes;
        CanvasID = canvasID;
    }

    public static Canvas CreateCanvas(String line) {
        String[] parts = line.split("\\s+");
        String id = parts[0];
        List<Shape> shapes = new ArrayList<>();

        for(int i = 1; i+1 < parts.length; i+=2) {
            String type = parts[i];
            double size = Double.parseDouble(parts[i+1]);
            if(type.equals("C")) {
                shapes.add(new Circle(type, size));
            }else if(type.equals("S")) {
                shapes.add(new Square(type, size));
            }
        }
        return new Canvas(shapes,id);

    }
    public static String getStats(Canvas canvas) {
        //total_shapes total_circles total_squares min_area max_area average_area.
        int count=canvas.shapes.size();
        int total_circles=canvas.shapes.stream().filter(p->p.getType().equals("C")).collect(Collectors.toList()).size();
        int total_Squares=canvas.shapes.stream().filter(p->p.getType().equals("S")).collect(Collectors.toList()).size();
        double min_area=canvas.shapes.stream().mapToDouble(Shape::getArea).min().orElse(0.0);
        double max_area=canvas.shapes.stream().mapToDouble(Shape::getArea).max().orElse(0.0);
        double avg_area=canvas.shapes.stream().mapToDouble(Shape::getArea).average().orElse(0.0);
        return String.format("%s %s %s %s %.2f %.2f %.2f",canvas.CanvasID,count,total_circles,total_Squares,min_area, max_area, avg_area);
    }
    public double getTotalArea() {
        return shapes.stream().mapToDouble(Shape::getArea).sum();
    }
    @Override
    public int compareTo(Canvas o) {
        return Double.compare(this.getTotalArea(), o.getTotalArea());
    }

    public List<Shape> getShapes() {
        return shapes;
    }

    public String getCanvasID() {
        return CanvasID;
    }
}
class ShapesApplication {
    private List<Canvas> canvas;
    private int MaxArea;

    public ShapesApplication(int maxArea) {
        MaxArea = maxArea;
        canvas = new ArrayList<>();
    }

    public void readCanvases(InputStream in) throws IOException{
        BufferedReader reader = new BufferedReader(new InputStreamReader(in));

        List<Canvas> result = new ArrayList<>();

        reader.lines().forEach(line -> {
            Canvas c = Canvas.CreateCanvas(line);

            try {
                // Check all shapes for max area violation
                for (Shape s : c.getShapes()) {
                    if (s.getArea() > MaxArea) {
                        throw new IrregularCanvasException(c.getCanvasID(), MaxArea);
                    }
                }

                result.add(c); // valid canvas

            } catch (IrregularCanvasException e) {
                System.out.println(e.getMessage()); // required output
            }
        });

        this.canvas = result;
    }

    public void printCanvases(PrintStream out) {
        PrintWriter pw = new PrintWriter(out);
        canvas.stream().sorted(Comparator.reverseOrder()).forEach(c->pw.println(Canvas.getStats(c)));
        pw.flush();
    }
}
class IrregularCanvasException extends Exception {
    public IrregularCanvasException(String canvasId, double maxArea) {
        super(String.format("Canvas %s has a shape with area larger than %.2f", canvasId, maxArea));
    }
}
